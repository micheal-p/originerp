{$API_DOMAIN} {
	# Auth (GoTrue)
	handle /auth/v1/* {
		reverse_proxy auth:9999
	}

	# PostgREST — data API
	handle /rest/v1/* {
		reverse_proxy rest:3000
	}

	# Storage API
	handle /storage/v1/* {
		reverse_proxy storage:5000
	}

	handle {
		respond "Collarone API — see /rest/v1, /auth/v1, /storage/v1" 200
	}

	encode gzip
}
