# Copy to .env on the VPS (never commit the real .env)

# --- Postgres ---
POSTGRES_PASSWORD=change-me-long-random

# --- JWT — generate with: node make-keys.mjs ---
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

# --- Domains ---
API_DOMAIN=api.collarone.com
SITE_URL=https://collarone.com

# --- SMTP (fill in once the collarone.app mailbox exists) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Collarone
