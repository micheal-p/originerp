# Collarone self-hosted server — copy to hosting/.env and fill in.
# NEVER commit the real .env.

# Port the Node service listens on (nginx proxies to this)
PORT=3001

# ---- Supabase (same project as today) ---------------------------------------
SUPABASE_URL=https://dxekronjsvnwmnbanlqh.supabase.co
# Service-role key — Supabase dashboard > Settings > API. Server-side ONLY.
SUPABASE_SERVICE_KEY=

# ---- crons ------------------------------------------------------------------
# Any random long string. Gates /api/automations-run; also lets you trigger it
# by hand: curl -H "Authorization: Bearer <secret>" https://collarone.app/api/automations-run
CRON_SECRET=

# ---- payments (Collarone's OWN Paystack — subscription revenue) -------------
PLATFORM_PAYSTACK_SECRET=

# ---- dunning ladder ---------------------------------------------------------
# 'true' = the overdue -> read-only -> suspended ladder advances automatically
# (5-day grace). Anything else = ladder paused, manual moves only.
PAYWALL_ENFORCE=true

# ---- email (Resend) ---------------------------------------------------------
RESEND_API_KEY=

# ---- AI letters (OpenAI) ----------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
